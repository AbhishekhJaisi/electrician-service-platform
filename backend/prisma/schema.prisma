generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Business {
  id         Int    @id @default(autoincrement())
  name       String
  owner      String
  tagline    String
  phone      String
  whatsapp   String
  email      String
  address    String
  hours      String
  years      Int
  ownerPhoto String @default("")
}

model Service {
  id     Int     @id @default(autoincrement())
  name   String
  desc   String
  price  Int
  unit   String  @default("starting")
  time   String
  icon   String
  order  Int     @default(0)
  active Boolean @default(true)
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  area      String
  rating    Int
  text      String
  date      String
  title     String   @default("")
  avatar    String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Area {
  id    Int    @id @default(autoincrement())
  name  String @unique
  order Int    @default(0)
}

model Enquiry {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String   @default("")
  service   String
  message   String   @default("")
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Booking {
  id            Int           @id @default(autoincrement())
  name          String
  phone         String
  address       String
  issueType     String
  preferredTime String?
  availability  String?
  notes         String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BookingStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  filename  String
  caption   String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
