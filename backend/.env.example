PORT=3000
NODE_ENV=development

# PostgreSQL — get from Railway / Neon / Supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/voltfix"

# JWT — generate at https://generate-secret.vercel.app/32
JWT_SECRET="change_this_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# ── WhatsApp Notifications (Twilio) ──────────────────────────────────────
# Sign up free at https://twilio.com — no credit card for sandbox testing
# 1. Get Account SID + Auth Token from https://console.twilio.com
# 2. Sandbox number is: whatsapp:+14155238886 (for testing)
# 3. For production apply for a real sender number

TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_WHATSAPP_FROM="+14155238886"   # Twilio sandbox number (testing)
ADMIN_WHATSAPP_NUMBER="+919876543210" # Owner's WhatsApp (receives notifications)
