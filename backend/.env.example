PORT=3000
NODE_ENV=development

# PostgreSQL — get this from Railway / Neon / Supabase when deploying
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/voltfix"

# Long random string — generate one at https://generate-secret.vercel.app/32
JWT_SECRET="change_this_to_a_long_random_string"
JWT_EXPIRES_IN="7d"
